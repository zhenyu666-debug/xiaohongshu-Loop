# Large data files
*.csv
*.csv.gz
*.parquet
data/
*.db

# Charts (regenerable PNG artifacts)
charts/*.png

# Flink jars
flink/lib/
iceberg-rest/lib/

# DuckDB railway datasets
duckdb_railway/

# All jar files
*.jar

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.env

# Scratch / debug files (leading underscore convention)
_*.py
_*.txt
_*.json
_*.sql
_*.md

# Other tmp
*.log
*.bak
*.tmp

# Don't duplicate the root LOOP-STATE.md
/LOOP-STATE.md

