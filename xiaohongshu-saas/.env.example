# ---- App ----
APP_NAME=xhs-saas
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080
APP_SECRET=change-me-please

# ---- Database ----
DATABASE_URL=sqlite+aiosqlite:///./data/xhs_saas.db

# ---- Redis (used for Celery + scheduler locks) ----
REDIS_URL=redis://redis:6379/0

# ---- Default channel ----
DEFAULT_CHANNEL=xiaohongshu

# ---- Anti-detection knobs ----
HUMAN_DELAY_MIN_MS=1200
HUMAN_DELAY_MAX_MS=4500
PROXY_ROTATE_EVERY=20
WARMUP_HOURS_BEFORE_SOLOPOST=24

# ---- Risk control ----
DAILY_POST_LIMIT_PER_ACCOUNT=5
HOURLY_POST_LIMIT_PER_ACCOUNT=2
COOL_DOWN_MINUTES_AFTER_FAIL=30

# ---- OpenAI / SiliconFlow (content factory) ----
OPENAI_API_KEY=
# Override base URL to use SiliconFlow or other OpenAI-compatible proxies.
# SiliconFlow: https://api.siliconflow.cn/v1
# Defaults to https://api.openai.com/v1 when empty.
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=Qwen/Qwen2.5-72B-Instruct

# ---- AI Agent settings (prefix: AI_) ----
# AI_LLM_PROVIDER=openai       # openai | anthropic | ollama
# AI_OPENAI_BASE_URL=          # inherits from OPENAI_BASE_URL
# AI_DEFAULT_MODEL=gpt-4o
# AI_VECTOR_STORE_TYPE=chroma   # chroma | faiss | qdrant

# ---- Channels (extensible) ----
ENABLE_XIAOHONGSHU=true
ENABLE_DOUYIN=false
ENABLE_KUAISHOU=false