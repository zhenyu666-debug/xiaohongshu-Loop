# ---- App ----
APP_NAME=xhs-saas
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080
APP_SECRET=change-me-please

# ---- Database ----
DATABASE_URL=sqlite+aiosqlite:///./data/xhs_saas.db

# ---- Redis (used for Celery + scheduler locks) ----
REDIS_URL=redis://redis:6379/0

# ---- Default channel ----
DEFAULT_CHANNEL=xiaohongshu

# ---- Anti-detection knobs ----
HUMAN_DELAY_MIN_MS=1200
HUMAN_DELAY_MAX_MS=4500
PROXY_ROTATE_EVERY=20
WARMUP_HOURS_BEFORE_SOLOPOST=24

# ---- Risk control ----
DAILY_POST_LIMIT_PER_ACCOUNT=5
HOURLY_POST_LIMIT_PER_ACCOUNT=2
COOL_DOWN_MINUTES_AFTER_FAIL=30

# ---- OpenAI (content factory) ----
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ---- Channels (extensible) ----
ENABLE_XIAOHONGSHU=true
ENABLE_DOUYIN=false
ENABLE_KUAISHOU=false