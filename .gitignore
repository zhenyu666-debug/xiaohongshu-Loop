# ===== WiX / MSI 构建产物 =====
# build/ 是构建中间目录（heat 输出 + wixobj）
installer/build/
# wixpdb 是调试符号，不要上传
installer/output/*.wixpdb
# 单个 wixobj 文件散落在根目录时（早期 build_msi 跑出来的）
Files.wixobj
product.wixobj

# 备注：frontend/ 目录要保留（智联 UI），不忽略
backend/target/

# ===== PyInstaller / 打包产物（要推！用户要求 exe 上仓库） =====
# dist/ 和 packages/ 保留（包含 xhs-saas-console.exe 单文件 195 MB）
# 但 onedir 模式生成的 _internal/ 太占体积（465 MB），忽略
dist/xhs-saas-console/_internal/
dist/xhs-saas-console-onefile/_internal/

# .spec 是 PyInstaller 生成的，可重新生成；不推
scripts/xhs-saas-console.spec

